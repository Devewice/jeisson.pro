# Copia a .env y ajusta valores (no subas .env a git)

# Login área interna (CV)
AUTH_USERNAME=jeisson
AUTH_PASSWORD=tu-contraseña-segura

# Mínimo 32 caracteres aleatorios en producción
SESSION_SECRET=genera-un-secreto-largo-y-aleatorio

# URL pública (enlaces de acceso al CV para invitados). En local puede ser https://jeisson.pro;
# con API_PORT la cookie de login no usa Secure aunque sea https.
PUBLIC_URL=https://jeisson.pro

# Desarrollo local (npm run dev): deja development o comenta NODE_ENV
NODE_ENV=development
PORT=3000

# Solo desarrollo (API separada de Vite)
API_PORT=3001

# PDF del CV (Chrome/Edge headless). Solo si no se detecta el navegador:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PDF_BASE_URL=http://localhost:3001

# Producción en servidor HTTPS (opcional)
# NODE_ENV=production
# COOKIE_SECURE=true
